{
  "name": "@truthcert-ma/core",
  "version": "1.0.0",
  "description": "Core statistical engine for meta-analysis",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./effect-size": {
      "import": "./dist/effect-size/index.esm.js",
      "require": "./dist/effect-size/index.js"
    },
    "./pooling": {
      "import": "./dist/pooling/index.esm.js",
      "require": "./dist/pooling/index.js"
    },
    "./bias": {
      "import": "./dist/bias/index.esm.js",
      "require": "./dist/bias/index.js"
    },
    "./clinical": {
      "import": "./dist/clinical/index.esm.js",
      "require": "./dist/clinical/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "node ../../scripts/build-core.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "meta-analysis",
    "statistics",
    "evidence-synthesis",
    "systematic-review",
    "metafor",
    "forest-plot",
    "heterogeneity"
  ],
  "author": "TruthCert Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/truthcert/truthcert-ma.git",
    "directory": "packages/core"
  },
  "devDependencies": {
    "typescript": "^5.3.2"
  }
}
